# PostgreSQL
POSTGRES_PASSWORD=cambia_esto

# API
DATABASE_URL=postgresql://atlas:cambia_esto@db:5432/atlas
JWT_SECRET=genera_un_secreto_largo_aqui

# Origenes CORS permitidos (URL del frontend)
CORS_ORIGINS=http://localhost,http://tu-servidor.com

# URL de la API que el navegador usara (Vite build-time)
VITE_API_BASE=http://tu-servidor.com:8000

# Opcional: crear admin inicial automaticamente
ATLAS_BOOTSTRAP_ORG_NAME=Mi Org
ATLAS_BOOTSTRAP_ADMIN_EMAIL=admin@ejemplo.com
ATLAS_BOOTSTRAP_ADMIN_PASSWORD=password_seguro
